# Copy to .env and adjust. Never commit real secrets.

# Required for API + migrations (matches root docker-compose.yml postgres service)
DATABASE_URL=postgres://todo:todo@127.0.0.1:5432/todos

# HTTP bind (optional)
PORT=3000
HOST=0.0.0.0

# CORS: single browser origin for the Vite app (optional). Not a comma-separated list.
WEB_ORIGIN=http://127.0.0.1:5173
