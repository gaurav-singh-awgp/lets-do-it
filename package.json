{
  "name": "lets-do-it",
  "private": true,
  "workspaces": ["api", "web"],
  "scripts": {
    "check:readme": "node scripts/check-readme-sections.mjs",
    "lint": "npm run lint -w web",
    "dev:api": "npm run dev -w api",
    "dev:web": "npm run dev -w web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test -w api",
    "test:web": "npm run test -w web",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "dev:e2e": "concurrently -k -n api,web -c blue,green \"npm run dev -w api\" \"wait-on -t 120000 -i 500 http://127.0.0.1:3000/health && npm run dev -w web -- --host 127.0.0.1 --port 5173 --strictPort\""
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.1"
  }
}
